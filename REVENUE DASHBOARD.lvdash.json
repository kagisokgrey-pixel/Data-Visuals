      "name": "b833bf1e",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "\n",
        "SELECT COUNT(DISTINCT `Customer ID`) AS Unique_Customers,\n",
        "       Date,\n",
        "     YEAR(Date) AS Trans_year, --Extract the year from  the date column\n",
        "\n",
        "     MONTH(DATE) AS Trans_Month,--Extract the Month from the date column\n",
        "     MONTHNAME(Date) AS Trans_Month_Name,--Extract the day name from the date Column\n",
        "\n",
        "     DAY(Date) AS Trans_Day, --Extract the day From the column\n",
        "     DAYNAME(Date) AS Trans_day_Name,--Extract the day name  fromthe date column\n",
        "\n",
        "     SUM(`Total Amount`) AS Revenue, --Calculate the total Revenue\n",
        "        `Product Category`\n",
        "FROM retail2.schema_retail.retail_sales_dataset\n",
        "GROUP BY ALL;"
      ]
    }
  ],
